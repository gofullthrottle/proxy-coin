# Database
DATABASE_URL=postgres://proxycoin:proxycoin_dev@localhost:5432/proxycoin?sslmode=disable

# Redis
REDIS_URL=redis://localhost:6379

# Backend Services
ORCHESTRATOR_ADDR=:8080
API_ADDR=:8081
METERING_ADDR=:8082
WS_ADDR=:8080

# JWT
JWT_SECRET=dev-secret-change-in-production

# Blockchain (Base L2)
BASE_RPC_URL=https://sepolia.base.org
BASE_SEPOLIA_RPC=https://sepolia.base.org
BASE_MAINNET_RPC=https://mainnet.base.org

# Contract Addresses (filled after deployment)
TOKEN_ADDRESS=
REWARD_DISTRIBUTOR_ADDRESS=
STAKING_ADDRESS=
VESTING_ADDRESS=

# Deployer (for contract deployment - NEVER commit real keys)
DEPLOYER_KEY=

# Basescan (for contract verification)
BASESCAN_API_KEY=

# Play Integrity (Android attestation)
PLAY_INTEGRITY_DECRYPTION_KEY=
PLAY_INTEGRITY_VERIFICATION_KEY=
